generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Prenotazione {
  id       Int      @id @default(autoincrement())
  data     String
  campo    String
  orario   String
  creataIl DateTime @default(now())
  utente   Utente?  @relation(fields: [utenteId], references: [id])
  utenteId Int?
}
model Utente {
  id           Int            @id @default(autoincrement())
  nome         String
  email        String         @unique
  password     String
  creataIl     DateTime       @default(now())
  prenotazioni Prenotazione[]
}