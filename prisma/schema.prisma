generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Prenotazione {
  id       Int      @id @default(autoincrement())
  data     String
  campo    String
  orario   String
  creataIl DateTime @default(now())
}